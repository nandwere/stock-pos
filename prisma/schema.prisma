// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
}

enum TransactionType {
  ADJUSTMENT_ADD
  ADJUSTMENT_REMOVE
  SALE
  DAMAGE
  THEFT
  EXPIRY
  CORRECTION
  RETURN
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  CREDIT
}

enum MerchantPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

// ─────────────────────────────────────────────
// Merchant  (tenant root)
// ─────────────────────────────────────────────

model Merchant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique   // e.g. "acme-shop" → acme-shop.yourapp.com
  email        String       @unique   // billing / contact email
  phone        String?
  address      String?
  logoUrl      String?
  currency     String       @default("KES")
  timezone     String       @default("Africa/Nairobi")
  plan         MerchantPlan @default(FREE)
  isActive     Boolean      @default(true)
  trialEndsAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  users        User[]
  categories   Category[]
  products     Product[]
  sales        Sale[]
  stockCounts  StockCount[]
  adjustments  StockAdjustment[]
  dailySummaries DailySummary[]
  shifts       Shift[]
  settings     Settings[]
  otpCodes   OtpCode[]
  paymentRequests PaymentRequest[]
  suppliers        Supplier[]
  expenses         Expense[]
  expenseCategories ExpenseCategory[]

  @@index([slug])
  @@index([email])
  @@index([plan])
}

model User {
  id            String   @id @default(cuid())
  merchantId    String
  email         String   @unique
  name          String
  role          UserRole @default(CASHIER)
  password      String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  merchant      Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  sales         Sale[]
  stockCounts   StockCount[]
  adjustments   StockAdjustment[]
  shifts        Shift[]
  expenses         Expense[]
  expenseApprovals ExpenseApproval[]
  
  // Email unique per merchant, not globally
  @@unique([merchantId, email])
  @@index([merchantId])
  @@index([merchantId, role])
  @@index([email])
}

model Category {
  id          String    @id @default(cuid())
  merchantId  String
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  

  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  products    Product[]
  
  @@unique([merchantId, name])
  @@index([merchantId])
}

model Product {
  id              String   @id @default(cuid())
  merchantId      String
  name            String
  description     String?
  sku             String   @unique
  barcode         String?  @unique
  categoryId      String
  costPrice       Decimal  @db.Decimal(10, 3)
  sellingPrice    Decimal  @db.Decimal(10, 3)
  currentStock  Decimal  @default(0)
  reorderLevel  Decimal  @default(0) 
  unit            String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  merchant        Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  category        Category @relation(fields: [categoryId], references: [id])
  saleItems       SaleItem[]
  stockCounts     StockCount[]
  adjustments     StockAdjustment[]
  // In Product model — add relation:
  supplierId       String?
  supplier         Supplier? @relation(fields: [supplierId], references: [id])
  
  // SKU and barcode unique per merchant
  @@unique([merchantId, sku])
  @@unique([merchantId, barcode])
  @@index([merchantId])
  @@index([merchantId, categoryId])
  @@index([merchantId, currentStock])
}

model Sale {
  id              String        @id @default(cuid())
  merchantId      String
  saleNumber      String        @unique
  userId          String
  customerName    String?
  paymentMethod   PaymentMethod
  subtotal        Decimal       @db.Decimal(10, 3)
  tax             Decimal       @db.Decimal(10, 3) @default(0)
  discount        Decimal       @db.Decimal(10, 3) @default(0)
  total           Decimal       @db.Decimal(10, 3)
  amountPaid      Decimal       @db.Decimal(10, 3)
  change          Decimal       @db.Decimal(10, 3) @default(0)
  notes           String?
  createdAt       DateTime      @default(now())
  
  merchant      Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])
  items           SaleItem[]
  
  // Sale number unique per merchant
  @@unique([merchantId, saleNumber])
  @@index([merchantId])
  @@index([merchantId, userId])
  @@index([merchantId, createdAt])
  @@index([merchantId, paymentMethod])
}

model SaleItem {
  id              String   @id @default(cuid())
  saleId          String
  productId       String
  quantity        Decimal  @db.Decimal(10, 3)
  unitPrice       Decimal  @db.Decimal(10, 3)
  subtotal        Decimal  @db.Decimal(10, 3)
  
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
  
  @@index([saleId])
  @@index([productId])
}

model StockCount {
  id              String   @id @default(cuid())
  merchantId      String
  productId       String
  userId          String
  expectedQty     Decimal  @db.Decimal(10, 3)
  actualQty       Decimal  @db.Decimal(10, 3)
  variance        Decimal  @db.Decimal(10, 3)
  notes           String?
  countDate       DateTime @default(now())
  
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
  
  @@index([merchantId])
  @@index([merchantId, productId])
  @@index([merchantId, countDate])
}

model StockAdjustment {
  id              String          @id @default(cuid())
  merchantId      String
  productId       String
  userId          String
  type            TransactionType
  quantity        Decimal  @db.Decimal(10, 3)
  reason          String
  notes           String?
  createdAt       DateTime        @default(now())
  
  merchant        Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  
  @@index([merchantId])
  @@index([merchantId, productId])
  @@index([merchantId, createdAt])
  @@index([merchantId, type])
}

model DailySummary {
  id                  String   @id @default(cuid())
  merchantId          String
  date                DateTime @unique @db.Date
  totalSales          Decimal  @db.Decimal(10, 3)
  totalCost           Decimal  @db.Decimal(10, 3)
  grossProfit         Decimal  @db.Decimal(10, 3)
  recordedSales       Decimal  @db.Decimal(10, 3)
  estimatedSales      Decimal  @db.Decimal(10, 3)
  cashSales           Decimal  @db.Decimal(10, 3)
  cardSales           Decimal  @db.Decimal(10, 3)
  mobilePayments      Decimal  @db.Decimal(10, 3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  merchant            Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  
  // One summary per merchant per day
  @@unique([merchantId, date])
  @@index([merchantId])
  @@index([merchantId, date])
}

model Shift {
  id              String   @id @default(cuid())
  merchantId      String
  userId          String
  startTime       DateTime
  endTime         DateTime?
  openingCash     Decimal  @db.Decimal(10, 3)
  closingCash     Decimal? @db.Decimal(10, 3)
  expectedCash    Decimal? @db.Decimal(10, 3)
  variance        Decimal? @db.Decimal(10, 3)
  notes           String?
  
  merchant        Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id])
  
  @@index([merchantId])
  @@index([merchantId, userId])
  @@index([merchantId, startTime])
}

model Settings {
  id              String   @id @default(cuid())
  merchantId      String
  key             String   @unique
  value           String
  description     String?
  updatedAt       DateTime @updatedAt

  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  
  // Key unique per merchant
  @@unique([merchantId, key])
  @@index([merchantId])
}

model OtpCode {
  id         String   @id @default(cuid())
  merchantId String
  email      String
  code       String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([email, merchantId])
  @@index([code])
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model PaymentRequest {
  id              String        @id @default(cuid())
  merchantId      String
  plan            MerchantPlan
  transactionCode String        @unique   // prevents double-submissions
  status          PaymentStatus @default(PENDING)
  notes           String?                 // admin can leave a rejection reason
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  merchant        Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
}


// ── Suppliers ────────────────────────────────────────────────────────────────

model Supplier {
  id          String   @id @default(cuid())
  merchantId  String
  name        String
  email       String?
  phone       String?
  address     String?
  contactName String?
  taxPin      String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  products    Product[] // supplier can be linked to products

  @@unique([merchantId, name])
  @@index([merchantId])
  @@index([merchantId, isActive])
}

// ── Expense Categories ───────────────────────────────────────────────────────

model ExpenseCategory {
  id          String   @id @default(cuid())
  merchantId  String
  name        String
  description String?
  color       String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  expenses    Expense[]

  @@unique([merchantId, name])
  @@index([merchantId])
}

// ── Expenses ─────────────────────────────────────────────────────────────────

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
  VOIDED
}

enum ExpenseType {
  OPERATIONAL
  CAPITAL
  RECURRING
  ONE_TIME
}

model Expense {
  id               String        @id @default(cuid())
  merchantId       String
  userId           String
  supplierId       String?
  categoryId       String?
  expenseNumber    String
  type             ExpenseType   @default(OPERATIONAL)
  status           ExpenseStatus @default(DRAFT)
  description      String
  amount           Decimal       @db.Decimal(10, 3)
  tax              Decimal       @db.Decimal(10, 3) @default(0)
  total            Decimal       @db.Decimal(10, 3)
  currency         String        @default("KES")
  expenseDate      DateTime
  dueDate          DateTime?
  paidAt           DateTime?
  paymentMethod    PaymentMethod?
  paymentReference String?
  receiptUrl       String?
  notes            String?
  isRecurring      Boolean       @default(false)
  recurringDay     Int?          // day of month for recurring
  tags             String[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  merchant         Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id])
  supplier         Supplier?        @relation(fields: [supplierId], references: [id])
  category         ExpenseCategory? @relation(fields: [categoryId], references: [id])
  approvals        ExpenseApproval[]
  items            ExpenseItem[]

  @@unique([merchantId, expenseNumber])
  @@index([merchantId])
  @@index([merchantId, status])
  @@index([merchantId, supplierId])
  @@index([merchantId, categoryId])
  @@index([merchantId, expenseDate])
  @@index([merchantId, type])
}

model ExpenseItem {
  id          String   @id @default(cuid())
  expenseId   String
  description String
  quantity    Decimal  @db.Decimal(10, 3)
  unitPrice   Decimal  @db.Decimal(10, 3)
  subtotal    Decimal  @db.Decimal(10, 3)

  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
}

model ExpenseApproval {
  id         String   @id @default(cuid())
  expenseId  String
  approverId String
  status     String   // APPROVED | REJECTED
  comment    String?
  decidedAt  DateTime?
  createdAt  DateTime @default(now())

  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  approver   User     @relation(fields: [approverId], references: [id])

  @@index([expenseId])
  @@index([approverId])
}
